import { useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';

import Header from './components/Header';
import Footer from './components/Footer';
import HomeView from './components/HomeView';
import AboutView from './components/AboutView';
import ProductsView from './components/ProductsView';
import IngredientsView from './components/IngredientsView';
import JournalView from './components/JournalView';
import ContactView from './components/ContactView';

export default function App() {
  const [activePage, setActivePage] = useState<string>('home');

  // Render the matching component based on navigation state
  const renderView = () => {
    switch (activePage) {
      case 'home':
        return <HomeView onNavigate={setActivePage} />;
      case 'about':
        return <AboutView onNavigate={setActivePage} />;
      case 'products':
        return <ProductsView onNavigate={setActivePage} />;
      case 'ingredients':
        return <IngredientsView />;
      case 'journal':
        return <JournalView />;
      case 'contact':
        return <ContactView />;
      default:
        return <HomeView onNavigate={setActivePage} />;
    }
  };

  return (
    <div id="app-root" className="min-h-screen bg-white flex flex-col justify-between selection:bg-sky/20 selection:text-navy">
      {/* Sticky Top Header */}
      <Header activePage={activePage} setActivePage={setActivePage} />

      {/* Main Content Area with animated page entry */}
      <main id="app-main-content" className="flex-grow">
        <AnimatePresence mode="wait">
          <motion.div
            key={activePage}
            initial={{ opacity: 0, y: 12 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -12 }}
            transition={{ duration: 0.35, ease: [0.16, 1, 0.3, 1] }}
          >
            {renderView()}
          </motion.div>
        </AnimatePresence>
      </main>

      {/* Dynamic footer with FDA disclaimer block */}
      <Footer activePage={activePage} setActivePage={setActivePage} />
    </div>
  );
}
